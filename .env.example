# App Configuration
VITE_APP_URL=https://your-app-url.netlify.app
VITE_API_URL=https://your-api-url.com

# Supabase Configuration (Get these from your Supabase project settings)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
VITE_SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# Shopify Integration (Get these from your Shopify app settings)
VITE_SHOPIFY_CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID_HERE
VITE_SHOPIFY_CLIENT_SECRET=YOUR_SHOPIFY_CLIENT_SECRET_HERE
VITE_SHOPIFY_REDIRECT_URI=https://your-app-url.netlify.app/shopify-callback

# Shopify Backend Keys (for Edge Functions and Netlify Functions)
# IMPORTANT: Use your Shopify App's Client Secret (also called API Secret Key)
# Shopify uses the SAME secret for both OAuth token exchange AND webhook HMAC verification
# There is NO separate "webhook secret" - do not create or use SHOPIFY_WEBHOOK_SECRET
SHOPIFY_CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID_HERE
SHOPIFY_CLIENT_SECRET=YOUR_SHOPIFY_CLIENT_SECRET_HERE

# Facebook Marketing API (Get these from your Facebook app settings)
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID_HERE
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET_HERE