VITE_SHOPIFY_CLIENT_SECRET=YOUR_SHOPIFY_CLIENT_SECRET_HERE
VITE_SHOPIFY_WEBHOOK_SECRET=YOUR_SHOPIFY_WEBHOOK_SECRET_HERE